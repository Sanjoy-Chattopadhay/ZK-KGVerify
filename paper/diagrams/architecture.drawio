<mxfile host="app.diagrams.net">
  <diagram name="System Architecture" id="arch">
    <mxGraphModel dx="700" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ========== LAYER 1: KG Reasoning ========== -->
        <mxCell id="L1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=6;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="660" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="L1t" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;KG Reasoning Layer&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontColor=#1a5276;" vertex="1" parent="1">
          <mxGeometry x="40" y="18" width="250" height="30" as="geometry"/>
        </mxCell>

        <!-- KG Dataset -->
        <mxCell id="kg" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Knowledge&lt;br&gt;Graph&lt;/b&gt;&lt;br&gt;&lt;i&gt;FB15k-237&lt;/i&gt;&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="65" width="120" height="90" as="geometry"/>
        </mxCell>

        <!-- GNN Training -->
        <mxCell id="train" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;GNN Training&lt;/b&gt;&lt;br&gt;Neg. Sampling&lt;br&gt;+ Ranking Loss&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="175" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- 4 Models in 2x2 grid -->
        <mxCell id="m1" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;TransE&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="230" y="60" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;RotatE&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="60" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m3" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;CompGCN&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="230" y="115" width="100" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;R-GCN&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="115" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- Prediction -->
        <mxCell id="pred" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Link Prediction&lt;/b&gt;&lt;br&gt;(h, r, ?) → t̂&lt;br&gt;Score: s&lt;br&gt;Embedding: &lt;b&gt;v&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="520" y="60" width="140" height="90" as="geometry"/>
        </mxCell>

        <!-- Metrics -->
        <mxCell id="met" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Metrics&lt;/b&gt;&lt;br&gt;MRR&lt;br&gt;Hits@1/3/10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="170" width="110" height="65" as="geometry"/>
        </mxCell>

        <!-- L1 Arrows -->
        <mxCell id="a1" style="rounded=1;strokeWidth=2;strokeColor=#333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="kg" target="train" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="rounded=1;strokeWidth=2;strokeColor=#333;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="train" target="m3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="rounded=1;strokeWidth=2;strokeColor=#333;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="m2" target="pred" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="rounded=1;strokeWidth=2;strokeColor=#333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="pred" target="met" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== LAYER 2: ZKP Verification ========== -->
        <mxCell id="L2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;arcSize=6;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="280" width="660" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="L2t" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;ZKP Verification Layer&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontColor=#1e8449;" vertex="1" parent="1">
          <mxGeometry x="40" y="288" width="280" height="30" as="geometry"/>
        </mxCell>

        <!-- Commit -->
        <mxCell id="com" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Pedersen&lt;br&gt;Commitment&lt;/b&gt;&lt;br&gt;&lt;i&gt;C = g&lt;sup&gt;v&lt;/sup&gt; · h&lt;sup&gt;r&lt;/sup&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="335" width="130" height="70" as="geometry"/>
        </mxCell>

        <!-- Prove -->
        <mxCell id="prv" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Proof Generation&lt;/b&gt;&lt;br&gt;Schnorr + Fiat-Shamir&lt;br&gt;&lt;i&gt;e = Hash(C‖A‖...)&lt;br&gt;s = k + e·v&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="230" y="330" width="170" height="80" as="geometry"/>
        </mxCell>

        <!-- Proof π -->
        <mxCell id="prf" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;Proof π&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;(C, A, e, s&lt;sub&gt;v&lt;/sub&gt;, s&lt;sub&gt;r&lt;/sub&gt;)&lt;/font&gt;" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.18;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="430" width="130" height="65" as="geometry"/>
        </mxCell>

        <!-- Verify -->
        <mxCell id="ver" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Verification&lt;/b&gt;&lt;br&gt;g&lt;sup&gt;s_v&lt;/sup&gt;·h&lt;sup&gt;s_r&lt;/sup&gt; ≟ A·C&lt;sup&gt;e&lt;/sup&gt;&lt;/font&gt;" style="shape=diamond;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;size=18;" vertex="1" parent="1">
          <mxGeometry x="430" y="395" width="190" height="100" as="geometry"/>
        </mxCell>

        <!-- Accept/Reject -->
        <mxCell id="res" value="&lt;font style=&quot;font-size:14px;color:#27ae60;&quot;&gt;&lt;b&gt;✓ Accept&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:14px;color:#c0392b;&quot;&gt;&lt;b&gt;✗ Reject&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="330" width="100" height="55" as="geometry"/>
        </mxCell>

        <!-- L2 Arrows -->
        <mxCell id="b1" style="rounded=1;strokeWidth=2;strokeColor=#333;" edge="1" source="com" target="prv" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2" style="rounded=1;strokeWidth=2;strokeColor=#333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" edge="1" source="prv" target="prf" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="420"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="b3" style="rounded=1;strokeWidth=2;strokeColor=#333;" edge="1" source="prf" target="ver" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b4" style="rounded=1;strokeWidth=2;strokeColor=#333;" edge="1" source="ver" target="res" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Cross-layer: Prediction to Commit -->
        <mxCell id="x1" value="&lt;font style=&quot;font-size:11px;&quot;&gt;embedding &lt;b&gt;v&lt;/b&gt;&lt;/font&gt;" style="rounded=1;strokeWidth=2;strokeColor=#c0392b;dashed=1;dashPattern=6 4;verticalAlign=bottom;" edge="1" source="pred" target="com" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="590" y="265"/>
              <mxPoint x="115" y="265"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ========== LAYER 3: Blockchain ========== -->
        <mxCell id="L3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;arcSize=6;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="20" y="540" width="660" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="L3t" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;Blockchain Audit Layer&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontColor=#7d6608;" vertex="1" parent="1">
          <mxGeometry x="40" y="548" width="280" height="30" as="geometry"/>
        </mxCell>

        <!-- Smart Contract -->
        <mxCell id="sc" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Smart Contract&lt;/b&gt;&lt;br&gt;logVerification()&lt;br&gt;getRecord()&lt;/font&gt;" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="595" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- Blocks -->
        <mxCell id="bl0" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;B&lt;sub&gt;0&lt;/sub&gt;&lt;/b&gt;&lt;br&gt;Genesis&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="240" y="600" width="80" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="bl1" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;B&lt;sub&gt;1&lt;/sub&gt;&lt;/b&gt;&lt;br&gt;TX&lt;sub&gt;1..10&lt;/sub&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="600" width="80" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="bl2" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;B&lt;sub&gt;2&lt;/sub&gt;&lt;/b&gt;&lt;br&gt;TX&lt;sub&gt;11..20&lt;/sub&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="460" y="600" width="80" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="bln" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;···&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="545" y="610" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Audit -->
        <mxCell id="aud" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Immutable&lt;br&gt;Audit Trail&lt;/b&gt;&lt;br&gt;Tamper-proof&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="575" y="590" width="90" height="70" as="geometry"/>
        </mxCell>

        <!-- TX Detail -->
        <mxCell id="txd" value="&lt;font style=&quot;font-size:11px;&quot;&gt;&lt;b&gt;Each TX:&lt;/b&gt; (model_id, (h,r,t), score, C, verified, Hash(π))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="680" width="360" height="35" as="geometry"/>
        </mxCell>

        <!-- L3 Arrows -->
        <mxCell id="c1" style="rounded=1;strokeWidth=2;strokeColor=#333;" edge="1" source="sc" target="bl0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c2" style="strokeWidth=2;strokeColor=#333;" edge="1" source="bl0" target="bl1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c3" style="strokeWidth=2;strokeColor=#333;" edge="1" source="bl1" target="bl2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c4" style="strokeWidth=2;strokeColor=#333;" edge="1" source="bl2" target="aud" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Cross-layer: Verify to Smart Contract -->
        <mxCell id="x2" value="&lt;font style=&quot;font-size:11px;&quot;&gt;result + Hash(π)&lt;/font&gt;" style="rounded=1;strokeWidth=2;strokeColor=#c0392b;dashed=1;dashPattern=6 4;verticalAlign=bottom;" edge="1" source="res" target="sc" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="525"/>
              <mxPoint x="120" y="525"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
