        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=10;align=center;" value="② Commit&#xa;v_hash = Hash(v) mod p&#xa;r ← random from ℤ_p&#xa;C = g^v · h^r mod p" vertex="1">
          <mxGeometry height="70" width="165" x="237.5" y="55" as="geometry" />
        </mxCell>
        <mxCell id="a23" edge="1" parent="1" source="s2" style="strokeWidth=2;strokeColor=#d6b656;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" target="s3">
          <mxGeometry relative="1" as="geometry" />
