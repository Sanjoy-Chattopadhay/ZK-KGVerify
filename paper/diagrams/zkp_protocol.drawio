        <mxCell id="s6b" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=10;align=center;" value="⑥b Verify Equation&#xa;LHS = g^(s_v) · h^(s_r) mod p&#xa;RHS = A · C^e mod p&#xa;Check: LHS = RHS ?" vertex="1">
          <mxGeometry height="60" width="175" x="685" y="185" as="geometry" />
        </mxCell>
        <mxCell id="props" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=1;fontSize=10;fontStyle=1;align=center;" value="Properties:  Soundness — Cannot forge without (v, r)  |  Zero-Knowledge — π reveals nothing about θ  |  Non-Interactive — Fiat-Shamir heuristic" vertex="1">
          <mxGeometry height="30" width="520" x="20" y="270" as="geometry" />
        </mxCell>
        <mxCell id="corr" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f5f5f5;strokeColor=#999;strokeWidth=1;fontSize=10;align=center;" value="Correctness:  g^(k_v+ev) · h^(k_r+er) = (g^k_v · h^k_r) · (g^v · h^r)^e = A · C^e  ✓" vertex="1">
