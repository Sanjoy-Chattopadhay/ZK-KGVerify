        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=10;align=center;" value="③ Announce&#xa;k_v, k_r ← random from ℤ_p&#xa;A = g^(k_v) · h^(k_r) mod p" vertex="1">
          <mxGeometry height="70" width="170" x="450" y="55" as="geometry" />
        </mxCell>
        <mxCell id="a34" edge="1" parent="1" source="s3" style="strokeWidth=2;strokeColor=#d6b656;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" target="s4">
          <mxGeometry relative="1" as="geometry" />
