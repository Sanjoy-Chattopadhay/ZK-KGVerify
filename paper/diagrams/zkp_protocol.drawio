        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=10;align=center;" value="① Predict&#xa;t̂ = argmax f_θ(h, r, t&#39;)&#xa;s = f_θ(h, r, t̂)&#xa;v = [e_h ‖ e_r ‖ e_t̂]" vertex="1">
