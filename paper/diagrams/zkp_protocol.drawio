        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=10;align=center;" value="④ Challenge (Fiat-Shamir)&#xa;H_pred = Hash(h‖r‖t‖s)&#xa;e = Hash(C‖A‖H_pred‖id) mod p" vertex="1">
          <mxGeometry height="70" width="190" x="670" y="55" as="geometry" />
