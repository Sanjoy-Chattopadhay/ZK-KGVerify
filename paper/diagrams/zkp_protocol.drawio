        <mxCell id="sendlbl" parent="1" style="text;html=0;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" value="Send π = (C, A, e, s_v, s_r, H_pred, id)" vertex="1">
          <mxGeometry height="20" width="270" x="185" y="190" as="geometry" />
        </mxCell>
        <mxCell id="vh" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontStyle=1;fontSize=13;" value="Verifier (Consumer)" vertex="1">
          <mxGeometry height="30" width="400" x="460" y="150" as="geometry" />
        </mxCell>
        <mxCell id="s6a" parent="1" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=10;align=center;" value="⑥a Recompute Challenge&#xa;e&#39; = Hash(C‖A‖H_pred‖id) mod p&#xa;Check: e&#39; = e ?" vertex="1">
          <mxGeometry height="60" width="170" x="460" y="185" as="geometry" />
        </mxCell>
        <mxCell id="a6" edge="1" parent="1" source="s6a" style="strokeWidth=2;strokeColor=#82b366;entryX=0;entryY=0.5;exitX=1;exitY=0.5;" target="s6b">
          <mxGeometry relative="1" as="geometry" />
