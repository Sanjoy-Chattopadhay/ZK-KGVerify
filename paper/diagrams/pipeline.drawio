<mxfile host="app.diagrams.net">
  <diagram name="Pipeline" id="pipe">
    <mxGraphModel dx="700" dy="520" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="520" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Row 1: Steps 1-3 -->
        <mxCell id="s1" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;① Load KG&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;FB15k-237&lt;br&gt;(h, r, t) triples&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="120" height="85" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;② Train GNNs&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;TransE, RotatE&lt;br&gt;CompGCN, R-GCN&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="195" y="25" width="130" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;③ Predict&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;(h, r, ?) → t̂&lt;br&gt;Score s, Embed &lt;b&gt;v&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="380" y="25" width="130" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="eval" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Evaluate&lt;/b&gt;&lt;br&gt;MRR, Hits@K&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="565" y="25" width="110" height="55" as="geometry"/>
        </mxCell>

        <!-- Row 1 arrows -->
        <mxCell id="a12" style="strokeWidth=2.5;strokeColor=#333;rounded=1;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a23" style="strokeWidth=2.5;strokeColor=#333;rounded=1;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3e" style="strokeWidth=2.5;strokeColor=#333;rounded=1;" edge="1" source="s3" target="eval" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connector down from step 3 to step 4 -->
        <mxCell id="adown" style="strokeWidth=2.5;strokeColor=#c0392b;rounded=1;dashed=1;dashPattern=6 4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="445" y="95" as="sourcePoint"/>
            <mxPoint x="445" y="145" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="adownlbl" value="&lt;font style=&quot;font-size:11px;color:#c0392b;&quot;&gt;&lt;b&gt;v&lt;/b&gt; (private)&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="455" y="108" width="80" height="20" as="geometry"/>
        </mxCell>

        <!-- Row 2: Steps 4-6 -->
        <mxCell id="s4" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;④ Commit&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;C = g&lt;sup&gt;v&lt;/sup&gt;·h&lt;sup&gt;r&lt;/sup&gt; mod p&lt;br&gt;Pedersen scheme&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="380" y="145" width="130" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s5" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;⑤ Prove&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;Schnorr-FS&lt;br&gt;Generate π&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="195" y="145" width="130" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;⑥ Verify&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;g&lt;sup&gt;s_v&lt;/sup&gt;·h&lt;sup&gt;s_r&lt;/sup&gt; ≟ A·C&lt;sup&gt;e&lt;/sup&gt;&lt;br&gt;✓ or ✗&lt;/font&gt;" style="shape=diamond;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;size=14;" vertex="1" parent="1">
          <mxGeometry x="10" y="135" width="130" height="90" as="geometry"/>
        </mxCell>

        <!-- Row 2 arrows (right to left) -->
        <mxCell id="a45" style="strokeWidth=2.5;strokeColor=#333;rounded=1;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a56" style="strokeWidth=2.5;strokeColor=#333;rounded=1;" edge="1" source="s5" target="s6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connector down to blockchain row -->
        <mxCell id="adown2" style="strokeWidth=2.5;strokeColor=#c0392b;rounded=1;dashed=1;dashPattern=6 4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="75" y="225" as="sourcePoint"/>
            <mxPoint x="75" y="275" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="adown2lbl" value="&lt;font style=&quot;font-size:11px;color:#c0392b;&quot;&gt;result + Hash(π)&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="85" y="238" width="110" height="20" as="geometry"/>
        </mxCell>

        <!-- Row 3: Blockchain -->
        <mxCell id="bcbg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="10" y="275" width="670" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="bclbl" value="&lt;font style=&quot;font-size:14px;&quot;&gt;&lt;b&gt;⑦ Blockchain Audit Layer&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;fontColor=#7d6608;" vertex="1" parent="1">
          <mxGeometry x="25" y="280" width="250" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="sc" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Smart&lt;br&gt;Contract&lt;/b&gt;&lt;/font&gt;" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#f5f5f5;strokeColor=#666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="315" width="90" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="b0" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;B&lt;sub&gt;0&lt;/sub&gt;&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="160" y="320" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="b1" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;B&lt;sub&gt;1&lt;/sub&gt;&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="250" y="320" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="b2" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;B&lt;sub&gt;2&lt;/sub&gt;&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="340" y="320" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="bdots" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;···&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="410" y="325" width="40" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="bn" value="&lt;font style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;B&lt;sub&gt;n&lt;/sub&gt;&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="455" y="320" width="60" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="audit" value="&lt;font style=&quot;font-size:13px;&quot;&gt;&lt;b&gt;Immutable&lt;br&gt;Audit Trail&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="315" width="100" height="55" as="geometry"/>
        </mxCell>

        <!-- Blockchain arrows -->
        <mxCell id="cb0" style="strokeWidth=2;strokeColor=#333;" edge="1" source="sc" target="b0" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c01" style="strokeWidth=2;strokeColor=#333;" edge="1" source="b0" target="b1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c12" style="strokeWidth=2;strokeColor=#333;" edge="1" source="b1" target="b2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="cna" style="strokeWidth=2;strokeColor=#333;" edge="1" source="bn" target="audit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
